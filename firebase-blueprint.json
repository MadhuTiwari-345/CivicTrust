{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "location": { "type": "string" },
        "ageRange": { "type": "string" },
        "isFirstTime": { "type": "boolean" },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Step": {
      "title": "Voting Journey Step",
      "description": "A single step in the voting journey",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "dueDate": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "status"]
    },
    "TimelineEvent": {
      "title": "Timeline Event",
      "description": "An election milestone event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["deadline", "voting", "info"] },
        "critical": { "type": "boolean" }
      },
      "required": ["title", "date", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/steps/{stepId}": {
      "schema": "Step",
      "description": "Individual journey steps for a user"
    },
    "/timeline": {
      "schema": "TimelineEvent",
      "description": "Global election timeline events"
    }
  }
}
